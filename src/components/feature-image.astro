---
import { Image } from "astro:assets";
import featureImage from "@/assets/dashboard-feature.jpg";
---

<section class="site-container border-x py-24 pt-8">
	<div class="site-container">
		<div class="mb-12 text-center">
			<h2 class="text-2xl font-semibold md:text-3xl">What you'll see</h2>
		</div>
		<div class="mx-auto mt-6 max-w-4xl">
			<div
				class="relative h-full rounded-2xl bg-gradient-to-bl from-primary via-background/70 to-primary after:absolute after:inset-[1px] after:rounded-[calc(1rem-1px)] after:bg-background/30 dark:via-background/50 dark:after:bg-card/50"
			>
				<!-- image bg glows -->
				<div
					class="absolute top-0 right-0 -z-10 mx-auto aspect-square w-[40%] bg-primary/70 blur-3xl"
					aria-hidden="true"
				>
				</div>
				<div
					class="absolute bottom-0 left-0 -z-10 mx-auto aspect-square w-[40%] bg-primary/70 blur-3xl"
					aria-hidden="true"
				>
				</div>

				<Image
					src={featureImage}
					alt="Dashboard preview"
					loading="lazy"
					width={1500}
					height={938}
					class="relative z-10 rounded-2xl p-1 md:rounded-xl md:p-2"
				/>
			</div>
		</div>
	</div>
</section>
