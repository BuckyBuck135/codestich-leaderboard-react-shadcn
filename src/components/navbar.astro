---
import Logo from "@assets/logo.svg"

interface Props {
	user?: { name: string; email: string } | null
}

const { user = null } = Astro.props

function getInitials(name: string) {
	return name
		.split(" ")
		.filter(Boolean)
		.slice(0, 2)
		.map((p) => p[0].toUpperCase())
		.join("")
}
---

<header
	class="sticky top-0 z-50 w-full border-b bg-background/80 backdrop-blur-sm"
>
	<div class="site-container flex h-14 items-center border-x">
		<a href="/" class="flex items-center">
			<Logo class="h-6 w-auto dark:invert" />
		</a>

		<div class="flex-1"></div>

		<nav class="flex items-center gap-0.5">
			<a
				href="https://discord.gg/"
				target="_blank"
				rel="noreferrer"
				aria-label="Discord"
				class="hidden size-9 items-center justify-center rounded-4xl text-sm transition-colors hover:bg-muted hover:text-foreground sm:inline-flex"
			>
				<svg
					xmlns="http://www.w3.org/2000/svg"
					width="16"
					height="16"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					stroke-linecap="round"
					stroke-linejoin="round"
				>
					<path d="M8 12a1 1 0 1 0 2 0a1 1 0 0 0 -2 0"></path>
					<path d="M14 12a1 1 0 1 0 2 0a1 1 0 0 0 -2 0"></path>
					<path
						d="M15.5 17c0 1 1.5 3 2 3c1.5 0 2.833 -1.667 3.5 -3c.667 -1.667 .5 -5.833 -1.5 -11.5c-1.457 -1.015 -3 -1.34 -4.5 -1.5l-.972 1.923a11.913 11.913 0 0 0 -4.053 0l-.975 -1.923c-1.5 .16 -3.043 .485 -4.5 1.5c-2 5.667 -2.167 9.833 -1.5 11.5c.667 1.333 2 3 3.5 3c.5 0 2 -2 2 -3"
					></path>
					<path d="M7 16.5c3.5 1 6.5 1 10 0"></path>
				</svg>
			</a>

			<div class="mx-2 hidden h-4 w-px bg-border sm:block"></div>

			<button
				id="theme-toggle"
				aria-label="Toggle theme"
				class="inline-flex size-9 items-center justify-center rounded-4xl text-sm transition-colors hover:bg-muted hover:text-foreground"
			>
				<svg
					id="icon-sun"
					xmlns="http://www.w3.org/2000/svg"
					width="16"
					height="16"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					stroke-linecap="round"
					stroke-linejoin="round"
					class="hidden"
				>
					<path d="M12 12m-4 0a4 4 0 1 0 8 0a4 4 0 1 0 -8 0"></path>
					<path
						d="M3 12h1m8 -9v1m8 8h1m-9 8v1m-6.4 -15.4l.7 .7m12.1 -.7l-.7 .7m0 11.4l.7 .7m-12.1 -.7l-.7 .7"
					></path>
				</svg>
				<svg
					id="icon-moon"
					xmlns="http://www.w3.org/2000/svg"
					width="16"
					height="16"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					stroke-linecap="round"
					stroke-linejoin="round"
				>
					<path
						d="M12 3c.132 0 .263 0 .393 0a7.5 7.5 0 0 0 7.92 12.446a9 9 0 1 1 -8.313 -12.454z"
					></path>
				</svg>
			</button>

			<div class="mx-2 h-4 w-px bg-border"></div>

			{
				user ? (
					<div class="flex items-center gap-2">
						<div class="flex size-8 items-center justify-center rounded-full bg-muted text-xs font-medium">
							{getInitials(user.name)}
						</div>
						<button
							id="sign-out-btn"
							class="inline-flex h-8 items-center justify-center rounded-4xl px-3 text-sm font-medium transition-colors hover:bg-muted hover:text-foreground"
						>
							Sign out
						</button>
					</div>
				) : (
					<div class="flex items-center gap-0.5">
						<a
							href="/auth/signin"
							class="inline-flex h-8 items-center justify-center rounded-4xl px-3 text-sm font-medium transition-colors hover:bg-muted hover:text-foreground"
						>
							Sign in
						</a>
						<a
							href="/auth/signup"
							class="inline-flex h-8 items-center justify-center rounded-4xl bg-primary px-3 text-sm font-medium text-primary-foreground transition-colors hover:bg-primary/80"
						>
							Sign up
						</a>
					</div>
				)
			}
		</nav>
	</div>
</header>

<script>
	const toggle = document.getElementById("theme-toggle")!
	const sun = document.getElementById("icon-sun")!
	const moon = document.getElementById("icon-moon")!

	function applyTheme(dark: boolean) {
		document.documentElement.classList.toggle("dark", dark)
		sun.classList.toggle("hidden", !dark)
		moon.classList.toggle("hidden", dark)
		localStorage.setItem("theme", dark ? "dark" : "light")
	}

	applyTheme(document.documentElement.classList.contains("dark"))

	toggle.addEventListener("click", () => {
		applyTheme(!document.documentElement.classList.contains("dark"))
	})

	document
		.getElementById("sign-out-btn")
		?.addEventListener("click", async () => {
			const { actions } = await import("astro:actions")
			await actions.signOut()
			window.location.href = "/auth/signin"
		})
</script>
