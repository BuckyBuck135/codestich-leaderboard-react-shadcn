---
import { IconTrophy, IconCurrencyDollar, IconUsers } from "@tabler/icons-react";

const features = [
	{
		title: "Post Your Win",
		description:
			"Sign up, head to the dashboard, look at the beautiful charts and tables, add your MRR, done.",
		Icon: IconTrophy,
	},
	{
		title: "Watch the Board Update",
		description:
			"Your MRR appears on the live leaderboard instantly. See exactly where you rank against the rest of the community.",
		Icon: IconCurrencyDollar,
	},
	// {
	// 	title: "Track Your Progress",
	// 	description:
	// 		"Your dashboard shows revenue over time, clients landed, and month-over-month trends — all in one place, no spreadsheets needed.",
	// 	Icon: IconCurrencyDollar,
	// },
	{
		title: "The Community Effect",
		description:
			"It doesn't matter where you are. Momentum compounds when the group sees you winning.",
		Icon: IconUsers,
	},
];
---

<section class="site-container border-x sm:py-18 md:py-24">
	<div class="mx-auto max-w-6xl">
		<div class="mb-12 text-center">
			<h2 class="text-2xl font-semibold md:text-3xl">How It Works</h2>
		</div>
		<div class="grid gap-8 sm:grid-cols-3">
			{
				features.map((feature, index) => (
					<div
						class={`group relative flex items-start gap-4 overflow-hidden rounded-lg border border-border bg-muted p-6 before:absolute before:top-[var(--mouse-y)] before:left-[var(--mouse-x)] before:h-[300px] before:w-[300px] before:-translate-x-1/2 before:-translate-y-1/2 before:bg-[radial-gradient(circle_closest-side,color-mix(in_oklch,var(--color-foreground)_6%,transparent)_0%,transparent_100%)] before:opacity-0 before:transition-opacity before:duration-500 hover:before:opacity-100 md:p-8 dark:bg-card`}
						data-spotlight
					>
						<div class="relative shrink-0 text-primary dark:text-sidebar-primary">
							<span class="flex size-10 items-center justify-center rounded-md bg-primary/10 transition-colors duration-500 group-hover:bg-primary/15 dark:bg-primary/30 dark:group-hover:bg-primary/35">
								<feature.Icon
									className="size-5"
									aria-hidden="true"
								/>
							</span>
						</div>
						<div>
							<h3 class="mb-2 font-semibold">{feature.title}</h3>
							<p class="text-sm text-muted-foreground">
								{feature.description}
							</p>
						</div>
					</div>
				))
			}
		</div>
	</div>
</section>

<script>
	function handleMouseMove(event: MouseEvent) {
		const card = event.currentTarget as HTMLElement;
		const rect = card.getBoundingClientRect();
		card.style.setProperty("--mouse-x", `${event.clientX - rect.left}px`);
		card.style.setProperty("--mouse-y", `${event.clientY - rect.top}px`);
	}

	const setupSpotlight = () => {
		document
			.querySelectorAll<HTMLElement>("[data-spotlight]")
			.forEach((card) => {
				card.addEventListener("mousemove", handleMouseMove);
			});
	};

	setupSpotlight();
	document.addEventListener("astro:after-swap", setupSpotlight);
</script>
