---
import Layout from "@/layouts/main.astro"
import { createClient } from "../lib/supabase"
import { DashboardPage } from "@/components/dashboard-page"

const supabase = createClient({
	request: Astro.request,
	cookies: Astro.cookies,
})

const {
	data: { user },
} = await supabase.auth.getUser()

// uncomment to NOT allow unauthenticated users to access the dashboard
// if (!data?.user) return Astro.redirect("/auth/signin")

let userProp = null
let agencyOwners: { id: string; name: string; agency: string }[] = []

if (user) {
	const { data: profile } = await supabase
		.from("user_profiles")
		.select("name, account_type, agency, url")
		.eq("id", user.id)
		.single()

	if (profile) {
		userProp = {
			id: user.id,
			name: profile.name ?? "",
			email: user.email ?? "",
			avatar: "",
			accountType: profile.account_type as "admin" | "agency owner" | null,
			agency: profile.agency as string | null,
			account_type: profile.account_type,
			url: profile.url as string | null,
		}

		if (profile.account_type === "admin") {
			const { data } = await supabase
				.from("user_profiles")
				.select("id, name, agency")
				.eq("account_type", "agency owner")
			agencyOwners = (data ?? []) as {
				id: string
				name: string
				agency: string
			}[]
		}
	}
}

async function fetchMetrics() {
	try {
		const { data, error } = await supabase.from("mrr").select(`
			value,
			user_profiles!inner(name, agency, url)
		`)
		if (error) throw error
		return ((data ?? []) as any[]).map((row) => ({
			name: row.user_profiles.name,
			agency: row.user_profiles.agency,
			url: row.user_profiles.url,
			value: row.value,
		}))
	} catch (error) {
		console.error("Failed to fetch metrics:", error)
		return []
	}
}

const metrics = await fetchMetrics()
---

<Layout user={userProp}>
	<DashboardPage
		client:load
		user={userProp}
		agencyOwners={agencyOwners}
		metrics={metrics}
	/>
</Layout>
